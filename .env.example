# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Inference bind address (127.0.0.1 recommended behind LiteLLM)
MLX_DEFAULT_SERVER_HOST=127.0.0.1

# Background health polling (seconds)
MLX_HEALTH_INTERVAL_SECONDS=30
MLX_RESTART_BACKOFF_SECONDS=30
MLX_INSTANCE_WATCHDOG_ENABLED=true
# Max seconds to wait for an inference port to free after stop (default 12)
MLX_STOP_PORT_RELEASE_TIMEOUT_SECONDS=12

# Nadir Gateway (OpenAI-compatible proxy, outside instance range 11400-11500)
# Loaded automatically from .env via mlx_orchestrator.settings (override=False).
NADIR_GATEWAY_HOST=127.0.0.1
NADIR_GATEWAY_PORT=11380
NADIR_GATEWAY_PROXY_TIMEOUT_SECONDS=300
NADIR_GATEWAY_ROUTE_CACHE_TTL_SECONDS=20
NADIR_GATEWAY_WAKE_TIMEOUT_SECONDS=300
NADIR_GATEWAY_WAKE_POLL_INTERVAL_SECONDS=1
NADIR_IDLE_OFFLOAD_ENABLED=true
NADIR_IDLE_CHECK_INTERVAL_SECONDS=60
NADIR_GATEWAY_PUBLIC_BASE_URL=http://127.0.0.1:11380
IMAGE_OUTPUT_TTL_SECONDS=3600

# Set to 1 during tests or one-off management commands
# MLX_DISABLE_INSTANCE_WATCHDOG=1
